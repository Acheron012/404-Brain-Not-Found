# Backend
# Shared provider config for the LLM-powered planning pipeline.
# Switch providers here without changing the agent code.
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash

# DeepSeek configuration.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional Hugging Face fallback.
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# Optional LangSmith tracing for agent runs.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=amd-hackathon-schedly

# Optional Django host override.
# Default in code: localhost,127.0.0.1,0.0.0.0,backend
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,backend

# Frontend
# For local frontend development outside Docker, leave VITE_API_BASE_URL empty
# so Vite can proxy /api, /docs, and /schema through vite.config.ts.
VITE_API_BASE_URL=

# For local frontend development outside Docker, this is the backend target used
# by the Vite dev proxy. In Docker Compose this is already set to http://backend:8000.
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
